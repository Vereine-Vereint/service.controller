
# --- https://docs.karakeep.app/configuration/environment-variables#authentication--signup ---
KARAKEEP_DOMAIN=

KARAKEEP_VERSION=0.31.0
KARAKEEP_CHROME_VERSION=124
KARAKEEP_MEILI_VERSION=v1.37.0

NEXTAUTH_SECRET=
MEILI_MASTER_KEY=

NEXTAUTH_URL=https://${KARAKEEP_DOMAIN}

MEILI_ADDR=http://karakeep-meilisearch:7700
BROWSER_WEB_URL=http://karakeep-chrome:9222

DB_WAL_MODE=true

# --- AI ---
# OPENAI_API_KEY: ...

# --- Crawler ---
# https://docs.karakeep.app/configuration/environment-variables/#crawler-configs
CRAWLER_FULL_PAGE_SCREENSHOT=true
CRAWLER_STORE_PDF=true
CRAWLER_FULL_PAGE_ARCHIVE=true
CRAWLER_VIDEO_DOWNLOAD=true

# --- Authentik OIDC ---
OAUTH_CLIENT_ID=
OAUTH_CLIENT_SECRET=
OAUTH_WELLKNOWN_URL=
OAUTH_PROVIDER_NAME=authentik
OAUTH_ALLOW_DANGEROUS_EMAIL_ACCOUNT_LINKING=true
DISABLE_PASSWORD_AUTH=true
# DISABLE_SIGNUPS=true
OAUTH_AUTO_REDIRECT=true